{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "乐易",
  "version": "0.1.0",
  "identifier": "com.kongbai.yueeasy",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "pnpm build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "乐易",
        "width": 1280,
        "height": 768,
        "minWidth": 800,
        "minHeight": 600,
        "resizable": true,
        "transparent": true,
        "decorations": false,
        "additionalBrowserArgs": "--disable-features=MediaSessionService,msWebOOUI,msPdfOOUI,msSmartScreenProtection",
        "windowEffects": {
          "effects": [
            "mica"
          ],
          "state": "followsWindowActiveState"
        }
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "nsis",
    "windows": {
      "allowDowngrades": true,
      "certificateThumbprint": null,
      "digestAlgorithm": null,
      "minimumWebview2Version": null,
      "nsis": {
        "languages": [
          "SimpChinese",
          "English"
        ]
      },
      "signCommand": null,
      "timestampUrl": null,
      "tsp": false,
      "webviewInstallMode": {
        "silent": true,
        "type": "downloadBootstrapper"
      },
      "wix": null
    },
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
